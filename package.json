{
  "name": "daily-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Self-Dignified Muslim Woman — Daily Tracker. Multi-user, modular, subscription-aware habit tracker.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter=./apps/* dev",
    "build": "pnpm -r --filter=./packages/* build && pnpm -r --filter=./apps/* build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:cov": "pnpm -r test:cov",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @daily-tracker/api prisma:migrate",
    "db:seed": "pnpm --filter @daily-tracker/api prisma:seed",
    "db:studio": "pnpm --filter @daily-tracker/api prisma:studio",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.7"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": ["prettier --write"],
    "*.{json,md,yml,yaml}": ["prettier --write"]
  }
}
