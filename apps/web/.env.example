# Web app environment variables.

# Base URL the browser uses to reach the API.
# - Local dev: http://localhost:4000  (talk directly to the local API)
# - Cloud (Vercel): leave EMPTY so the client uses the relative /api/v1 path,
#   which is proxied to the API by the rewrite in next.config.mjs (same-origin).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Server-side proxy target for the /api/* rewrite (used in the cloud).
# Set to the deployed API origin, e.g. https://daily-tracker-api.onrender.com
# Leave unset for local dev (no proxy needed).
# API_ORIGIN=
